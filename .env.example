HOST=127.0.0.1
PORT=7676
# Owner password generated by `agentic init` in ~/.agentic/auth.json. Set this
# only for non-interactive or fully env-driven deployments.
# AGENTIC_OAUTH_OWNER_TOKEN=change-me-to-a-long-random-secret
# Optional OAuth tuning.
# AGENTIC_OAUTH_ACCESS_TOKEN_TTL_SECONDS=3600
# AGENTIC_OAUTH_REFRESH_TOKEN_TTL_SECONDS=2592000
# AGENTIC_OAUTH_SCOPES=agentic
# AGENTIC_OAUTH_ALLOWED_REDIRECT_HOSTS=chatgpt.com,localhost,127.0.0.1
# Comma-separated list of absolute paths this server is allowed to access.
# Never use wildcards, root directories, or sensitive paths (e.g. C:\Users or /home/user).
# Limit access precisely to the projects you intend to edit.
# AGENTIC_ALLOWED_ROOTS=/home/your-user/workspace/project-a,C:\Users\username\Projects\project-b
# For temporary tunnels, prefer setting this per run. Agentic MCP derives the
# inbound Host allowlist from this URL.
# AGENTIC_PUBLIC_BASE_URL=https://your-public-host.example.com
# Advanced escape hatch. `*` disables Host header allowlist protection.
# AGENTIC_ALLOWED_HOSTS=localhost,127.0.0.1,your-public-host.example.com
# Tool access mode: 'minimal', 'assistant', 'full' (default: assistant)
AGENTIC_TOOL_MODE="assistant"
# off | changes | full. Defaults to changes.
# changes creates one aggregate review widget via review_changes instead of per-tool iframes.
AGENTIC_WIDGETS=changes
AGENTIC_LOG_LEVEL=info
AGENTIC_LOG_FORMAT=json
AGENTIC_LOG_REQUESTS=1
AGENTIC_LOG_ASSETS=0
AGENTIC_LOG_TOOL_CALLS=1
AGENTIC_LOG_SHELL_COMMANDS=0
# AGENTIC_TRUST_PROXY=0
# AGENTIC_STATE_DIR=/home/user/.local/share/agentic
# AGENTIC_WORKTREE_ROOT=/home/user/.agentic/worktrees
# AGENTIC_STRICT_PVDL=0
# Optional paths to define custom agents or skills
# AGENTIC_AGENT_DIR=/path/to/agents
# AGENTIC_SKILL_PATHS=/path/to/skills
